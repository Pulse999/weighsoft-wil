## DataTables Integration

### Standard DataTable Pattern

```html
<table datatable="ng" class="table table-striped">
  <thead>
    <tr>
      <th>Column 1</th>
      <th>Column 2</th>
    </tr>
  </thead>
  <tbody>
    <tr ng-repeat="item in System.list">
      <td>{{ item.field1 }}</td>
      <td>{{ item.field2 }}</td>
    </tr>
  </tbody>
</table>
```

**Note**: DataTables assets must be loaded in route `resolve`:

```javascript
resolve: {
  deps: function ($ocLazyLoad) {
    return $ocLazyLoad.load([
      ASSETS.tables.datatables,
    ]);
  },
}
```

## Form Validation

### Angular Form Validation

```html
<form name="myForm" ng-submit="System.saveForm(myForm)" novalidate>
  <div class="form-group" ng-class="{'has-error': myForm.name.$invalid && myForm.name.$touched}">
    <label>Name</label>
    <input 
      type="text" 
      class="form-control" 
      ng-model="System.data.name"
      name="name"
      required
      minlength="3">
    <span ng-if="myForm.name.$error.required && myForm.name.$touched" class="help-block">
      Name is required
    </span>
    <span ng-if="myForm.name.$error.minlength && myForm.name.$touched" class="help-block">
      Name must be at least 3 characters
    </span>
  </div>
  
  <button 
    type="submit" 
    class="btn btn-primary"
    ng-disabled="myForm.$invalid">
    Save
  </button>
</form>
```

### Validation in Controller

```javascript
vm.saveForm = function(formData) {
  if (!formData.$valid) {
    return;  // Form validation errors will be shown
  }
  // Proceed with save
};
```

