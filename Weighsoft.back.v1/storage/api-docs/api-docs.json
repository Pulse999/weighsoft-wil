        "/api/camera/{id}": {
            "delete": {
                "tags": [
                    "Cameras"
                ],
                "summary": "Delete a camera",
                "description": "Deletes a camera by ID",
                "operationId": "deleteCamera",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of the camera to delete",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Camera deleted successfully"
                    },
                    "404": {
                        "description": "Camera not found"
