            }
        },
        "/api/getImageFromIpString": {
            "post": {
                "tags": [
                    "Camera"
                ],
                "summary": "Get image from IP string",
                "description": "Get image from IP string and return it as base64 encoded string",
                "operationId": "getImageFromIpString",
                "requestBody": {
                    "description": "IP address of the camera",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "imageUrl"
                                ],
                                "properties": {
                                    "imageUrl": {
                                        "type": "string",
                                        "example": "http://192.168.1.10/image.jpg"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Base64 encoded image",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                },
                                "example": "iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAMAAAAoLQ9TAAAABGdBTUEAALGPC/xhBQAAAAFzUkdCAK7OHOkAAAAMUExURQAAAP///wAAAMbGxv///yH5BAEAAAAALAAAAAABAAEAAAICRAEAOw=="
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The imageUrl field is required."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Failed to get image from IP address."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
